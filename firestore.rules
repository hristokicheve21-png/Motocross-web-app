rules_version = '2';

// Paste these rules into your Firebase Console:
// Firebase Console → Firestore Database → Rules tab → Replace all → Publish

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: users can only read their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.role == 'guest';
      allow update, delete: if false; // Only editable via Firebase Console
    }

    // All motocross data collections: anyone can read, only admins can write
    match /motocross_racers/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /motocross_races/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /motocross_heats/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /motocross_categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /motocross_tracks/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
